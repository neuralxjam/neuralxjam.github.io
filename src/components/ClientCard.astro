---
export interface Props {
  title: string;
  desc: string;
  status: "Live" | "Building";
  stack?: string;
  url?: string;       // live demo / external link
  detailUrl?: string; // portfolio detail page
}

const { title, desc, status, stack, url, detailUrl } = Astro.props;
const isLive = status === "Live";
---

<div class="card bg-base-200 hover:bg-base-300 transition-colors h-full border border-base-300 flex flex-col">
  <div class="card-body p-5 gap-2 flex flex-col flex-1">
    <div class="flex items-start justify-between gap-2">
      <h3 class="text-base font-bold leading-tight m-0">{title}</h3>
      <span class={`badge badge-sm shrink-0 ${isLive ? "badge-success" : "badge-warning"}`}>
        {status}
      </span>
    </div>
    <p class="text-sm opacity-75 leading-snug m-0 flex-1">{desc}</p>
    {stack && <div class="text-xs opacity-50 font-mono mt-1">{stack}</div>}
    {isLive && (url || detailUrl) && (
      <div class="flex flex-wrap gap-2 mt-3 pt-3 border-t border-base-300">
        {url && (
          <a href={url} target="_blank" class="btn btn-xs btn-primary">
            Live site →
          </a>
        )}
        {detailUrl && (
          <a href={detailUrl} class="btn btn-xs btn-outline">
            Details →
          </a>
        )}
      </div>
    )}
  </div>
</div>
