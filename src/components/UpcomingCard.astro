---
export interface Props {
  title: string;
  desc: string;
  status: "Building" | "Planned";
  stack?: string;
}

const { title, desc, status, stack } = Astro.props;
const statusBadge = status === "Building" ? "badge-warning" : "badge-ghost";
---

<div class="card bg-base-200 hover:bg-base-300 transition-colors h-full border border-base-300">
  <div class="card-body p-5 gap-2">
    <div class="flex items-start justify-between gap-2">
      <h3 class="text-base font-bold leading-tight m-0">{title}</h3>
      <span class={`badge badge-sm ${statusBadge} shrink-0`}>{status}</span>
    </div>
    <p class="text-sm opacity-75 leading-snug m-0">{desc}</p>
    {stack && <div class="text-xs opacity-60 mt-1 font-mono">{stack}</div>}
  </div>
</div>
