---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">

  <!-- Header + Download button -->
  <div class="flex items-start justify-between mb-8 flex-wrap gap-4">
    <div>
      <div class="text-3xl w-full font-bold">Resume</div>
    </div>
    <a
      href="/JhamesAndrewMacabata_Resume.pdf"
      download
      class="btn btn-neutral btn-sm gap-2"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
      </svg>
      Download PDF
    </a>
  </div>

  <!-- Summary -->
  <div class="mb-6 text-sm opacity-80 leading-relaxed">
    Computer Science graduate building a career at the intersection of software engineering, data, and AI — fields
    I find genuinely exciting because they create real-world impact. I am currently expanding my expertise in
    backend development, data engineering, and machine learning through hands-on projects and continuous learning.
  </div>

  <div class="divider my-2"></div>

  <!-- Work Experience -->
  <div class="mb-6">
    <div class="text-xs font-bold uppercase tracking-widest opacity-40 mb-4">Work Experience</div>

    <div class="mb-5">
      <div class="flex justify-between items-start flex-wrap gap-1 mb-2">
        <div>
          <div class="font-bold">Software / Web Developer</div>
          <div class="text-sm opacity-60">8Con Academy</div>
        </div>
        <div class="text-sm opacity-50">June 2025 – Present</div>
      </div>
      <ul class="list-disc list-inside text-sm opacity-75 space-y-1 ml-1">
        <li>Led development of an advanced automation system, achieving a 15% increase in operational efficiency.</li>
        <li>Streamlined manufacturing processes, reducing production costs by 10%.</li>
        <li>Implemented preventive maintenance strategies, resulting in a 20% decrease in equipment downtime.</li>
      </ul>
    </div>

    <div class="mb-2">
      <div class="flex justify-between items-start flex-wrap gap-1 mb-2">
        <div>
          <div class="font-bold">CS Intern</div>
          <div class="text-sm opacity-60">8Con Academy</div>
        </div>
        <div class="text-sm opacity-50">May 2025 – June 2025</div>
      </div>
      <ul class="list-disc list-inside text-sm opacity-75 space-y-1 ml-1">
        <li>Designed and optimised a robotic control system, realizing a 12% performance improvement.</li>
        <li>Coordinated testing and validation, ensuring compliance with industry standards.</li>
        <li>Provided technical expertise, contributing to a 15% reduction in system failures.</li>
      </ul>
    </div>
  </div>

  <div class="divider my-2"></div>

  <!-- Projects -->
  <div class="mb-6">
    <div class="text-xs font-bold uppercase tracking-widest opacity-40 mb-4">Projects</div>

    <div class="space-y-5">

      <div>
        <div class="flex justify-between items-start flex-wrap gap-1">
          <div>
            <div class="font-bold">8Con Edge — Thesis Project</div>
            <div class="text-xs opacity-55 italic">Lead Developer</div>
          </div>
          <a href="https://8conedge.com" target="_blank" class="text-xs link link-hover opacity-50">www.8conedge.com</a>
        </div>
        <ul class="list-disc list-inside text-sm opacity-75 space-y-1 ml-1 mt-1">
          <li>Designed a 9-indicator consensus engine with ML-augmented signals.</li>
          <li>Built a forex fundamental analysis decision support system and deployed to production with RBAC.</li>
        </ul>
      </div>

      <div>
        <div class="flex justify-between items-start flex-wrap gap-1">
          <div>
            <div class="font-bold">8Con Academy Website — Internship Project</div>
            <div class="text-xs opacity-55 italic">Team Lead Developer</div>
          </div>
          <a href="https://8conacademy.com" target="_blank" class="text-xs link link-hover opacity-50">www.8conacademy.com</a>
        </div>
        <ul class="list-disc list-inside text-sm opacity-75 space-y-1 ml-1 mt-1">
          <li>Developed a full-stack marketing platform for a forex trading school.</li>
          <li>Integrated Nodemailer for transactional emails delivering a complete lead-capture workflow.</li>
        </ul>
      </div>

      <div>
        <div class="flex justify-between items-start flex-wrap gap-1">
          <div>
            <div class="font-bold">Jkloting Website — Client Project</div>
            <div class="text-xs opacity-55 italic">Developer</div>
          </div>
          <a href="https://jkloting.store" target="_blank" class="text-xs link link-hover opacity-50">www.jkloting.store</a>
        </div>
        <ul class="list-disc list-inside text-sm opacity-75 space-y-1 ml-1 mt-1">
          <li>Built and deployed a marketing and quote-request site for a custom apparel business.</li>
          <li>Implemented AJAX quote forms via Web3Forms with a fully serverless, zero-backend architecture.</li>
        </ul>
      </div>

      <div>
        <div class="flex justify-between items-start flex-wrap gap-1">
          <div>
            <div class="font-bold">StaySure — Hotel Cancellation Predictor</div>
            <div class="text-xs opacity-55 italic">Developer</div>
          </div>
          <a href="https://huggingface.co/spaces/neuralxjam/staysure" target="_blank" class="text-xs link link-hover opacity-50">huggingface.co/spaces/neuralxjam/staysure</a>
        </div>
        <ul class="list-disc list-inside text-sm opacity-75 space-y-1 ml-1 mt-1">
          <li>Trained a Random Forest classifier on 119,390 hotel bookings achieving F1 = 0.85 and AUC = 0.958 across LR, RF, and XGBoost baselines.</li>
        </ul>
      </div>

    </div>
  </div>

  <div class="divider my-2"></div>

  <!-- Education -->
  <div class="mb-6">
    <div class="text-xs font-bold uppercase tracking-widest opacity-40 mb-4">Education</div>

    <div class="space-y-4">
      <div class="flex justify-between items-start flex-wrap gap-1">
        <div>
          <div class="font-bold">Bachelor of Science in Computer Science</div>
          <div class="text-sm opacity-60">Pambayang Dalubhasaan ng Marilao</div>
        </div>
        <div class="text-sm opacity-50">June 2022 – May 2026</div>
      </div>
      <div class="flex justify-between items-start flex-wrap gap-1">
        <div>
          <div class="font-bold">Bachelor of Science in Electrical Engineering</div>
          <div class="text-sm opacity-60">Polytechnic University of the Philippines — Sta. Mesa Campus</div>
        </div>
        <div class="text-sm opacity-50">Aug 2020 – Feb 2022</div>
      </div>
    </div>
  </div>

  <div class="divider my-2"></div>

  <!-- Skills -->
  <div class="mb-6">
    <div class="text-xs font-bold uppercase tracking-widest opacity-40 mb-3">Technical Skills</div>
    <div class="text-sm space-y-1.5 opacity-80">
      <div><span class="font-semibold">Languages:</span> Python, JavaScript, SQL</div>
      <div><span class="font-semibold">Backend:</span> FastAPI, Node.js, Express, Strapi</div>
      <div><span class="font-semibold">Frontend:</span> React, HTMX, Tailwind CSS</div>
      <div><span class="font-semibold">Databases:</span> PostgreSQL, MySQL, DuckDB, Redis, Supabase</div>
      <div><span class="font-semibold">Data & ML:</span> pandas, dbt, scikit-learn, XGBoost, SHAP, Streamlit</div>
      <div><span class="font-semibold">DevOps:</span> Docker, GitHub Actions, Nginx, Git</div>
      <div><span class="font-semibold">Platforms:</span> Render, Railway, Hugging Face, Cloudflare Workers</div>
    </div>
  </div>

  <div class="divider my-2"></div>

  <!-- Achievements -->
  <div class="mb-10">
    <div class="text-xs font-bold uppercase tracking-widest opacity-40 mb-3">Key Achievements</div>
    <ul class="list-disc list-inside text-sm opacity-75 space-y-1.5 ml-1">
      <li>Best Thesis — 2026 BSCS Public Forum (8ConEdge, Group Leader)</li>
      <li>Software / Web Developer — 8Con Academy (promoted from CS Intern)</li>
      <li>3rd Place — Java Programming Competition</li>
      <li>Champion — 2019 Division Science Fair, Robotics Team Category (Team Leader)</li>
    </ul>
  </div>

</BaseLayout>
