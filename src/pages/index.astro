---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import UpcomingCard from "../components/UpcomingCard.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hi 👋</div>
    <div class="text-5xl font-bold">I'm Jhames Andrew Macabata</div>
    <div class="text-3xl py-3 font-bold">Software · Data · AI/ML</div>
    <div class="py-2">
      <text class="text-lg">
        Fresh CS graduate (8Con Academy) building production software, data pipelines, and machine learning.
        Five shipped projects span the stack — full-stack web, data engineering, applied ML, a multi-tier SaaS
        thesis, and a containerised cloud service with CI/CD. Open to entry-level <b>Software Engineering</b>,
        <b>Data Engineering</b>, and <b>AI/ML</b> roles.
      </text>
    </div>
    <div class="mt-8">
      <a class="btn" href="/projects">View Projects</a>
      <a href="https://github.com/neuralxjam" target="_blank" class="btn btn-outline ml-5">
        GitHub
      </a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Featured projects {"</>"}</div>
  </div>

  <HorizontalCard
    title="Edge (8ConEdge) — Forex Trading Platform"
    img="/projects/edge.gif"
    desc="CS thesis: multi-tier full-stack SaaS that ranks forex pairs by 9-indicator macroeconomic consensus, augmented with a Python GBDT model. React 19 · Express 5 · Python Flask · MySQL (two pools) · Docker + Nginx. Role + tier access, single-tab enforcement, multi-format report export."
    url="/projects/edge"
    target="_self"
    badge="Thesis · Full-Stack + ML"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="StaySure — Hotel Booking Cancellation Predictor"
    img="/projects/staysure.gif"
    desc="Random Forest classifier hits F1=0.85, AUC=0.958 on 119k real bookings. Full ML lifecycle: EDA → feature engineering → model comparison → SHAP explainability → Gradio demo on Hugging Face Spaces."
    url="/projects/staysure"
    target="_self"
    badge="ML"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="CryptoPulse — Crypto Market ETL & Dashboard"
    img="/projects/cryptopulse.gif"
    desc="Daily ETL pipeline: CoinGecko API → DuckDB → dbt models → Streamlit dashboard. Runs every 6 hours via GitHub Actions cron. dbt docs site published on GitHub Pages."
    url="/projects/cryptopulse"
    target="_self"
    badge="Data Eng"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="MiniLink — Containerized URL Shortener"
    img="/projects/minilink.gif"
    desc="Self-hosted URL shortener with redirect analytics. FastAPI + PostgreSQL + Redis read-through cache, multi-stage Docker build, Docker Compose local dev, CI/CD pipeline to GHCR, deployed to Railway."
    url="/projects/minilink"
    target="_self"
    badge="DevOps · Docker · Railway"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="JobTrail — Job Application Tracker"
    img="/projects/jobtrail.gif"
    desc="Full-stack FastAPI + PostgreSQL + HTMX. Magic-link auth, inline editing, a status dashboard. Built during my own job hunt because spreadsheets lose context fast. Deployed on Render."
    url="/projects/jobtrail"
    target="_self"
    badge="Full-Stack"
  />

  <div class="mt-16 mb-8">
    <div class="text-3xl w-full font-bold mb-2">What's next {"</>"}</div>
    <p class="text-sm opacity-75 mb-5">A roadmap of work in progress and planned next steps. Each will graduate to Featured once shipped.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <UpcomingCard
        title="PCCI Membership Platform"
        desc="Client work for a Philippine chamber of commerce — role-based dues tracking, multi-channel payments, automated notifications."
        status="Building"
        stack="Laravel 12 · PostgreSQL · Sanctum · Tailwind"
      />
      <UpcomingCard
        title="WatchTower"
        desc="Observability stack for self-hosted services — metrics, logs, and alerts layered onto containerized apps."
        status="Planned"
        stack="Prometheus · Grafana · Loki"
      />
      <UpcomingCard
        title="InfraKit"
        desc="Reusable IaC templates for shipping small production apps fast — DNS, edge routing, secrets, CI/CD."
        status="Planned"
        stack="Terraform · Cloudflare · GitHub Actions"
      />
    </div>
  </div>

</BaseLayout>
