---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import UpcomingCard from "../components/UpcomingCard.astro";
import ClientCard from "../components/ClientCard.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hi 👋</div>
    <div class="text-5xl font-bold">I'm Jhames Andrew Macabata</div>
    <div class="text-3xl py-3 font-bold">Software Engineering · Data Engineering · AI/ML · AI Automation</div>
    <div class="py-2">
      <text class="text-lg">
        I build things that work in the real world — full-stack web apps, automated data pipelines, and deployed ML models. CS graduate, currently employed, and open to full-time roles in software engineering, data, and AI.
      </text>
    </div>
    <div class="inline-flex items-center gap-2 text-sm opacity-70 mb-4 mt-2">
      <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
      Open to full-time roles — Software Engineering, Data, AI
    </div>
    <div class="mt-8">
      <a class="btn" href="mailto:jam.macabata@outlook.com">Get in Touch</a>
      <a href="/projects" class="btn btn-outline ml-5">View Projects</a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Featured projects {"</>"}</div>
  </div>

  <HorizontalCard
    title="Edge (8ConEdge) — Forex Market Scanner"
    img="/projects/edge.gif"
    desc="CS thesis: multi-tier full-stack SaaS that ranks forex pairs by 9-indicator macroeconomic consensus, augmented with a Python GBDT model. React 19 · Express 5 · Python Flask · MySQL (two pools) · Docker + Nginx. Role + tier access, single-tab enforcement, multi-format report export."
    url="/projects/edge"
    target="_self"
    badge="Thesis · Full-Stack + ML"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="StaySure — Hotel Booking Cancellation Predictor"
    img="/projects/staysure.gif"
    desc="Random Forest classifier hits F1=0.85, AUC=0.958 on 119k real bookings. Full ML lifecycle: EDA → feature engineering → model comparison → SHAP explainability → Gradio demo on Hugging Face Spaces."
    url="/projects/staysure"
    target="_self"
    badge="ML"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="CryptoPulse — Crypto Market ETL & Dashboard"
    img="/projects/cryptopulse.gif"
    desc="Daily ETL pipeline: CoinGecko API → DuckDB → dbt models → Streamlit dashboard. Runs every 6 hours via GitHub Actions cron. dbt docs site published on GitHub Pages."
    url="/projects/cryptopulse"
    target="_self"
    badge="Data Eng"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="MiniLink — Containerized URL Shortener"
    img="/projects/minilink.gif"
    desc="Self-hosted URL shortener with redirect analytics. FastAPI + PostgreSQL + Redis read-through cache, multi-stage Docker build, Docker Compose local dev, CI/CD pipeline to GHCR, deployed to Railway."
    url="/projects/minilink"
    target="_self"
    badge="DevOps · Docker · Railway"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="JobTrail — Job Application Tracker"
    img="/projects/jobtrail.gif"
    desc="Full-stack FastAPI + PostgreSQL + HTMX. Magic-link auth, inline editing, a status dashboard. Built during my own job hunt because spreadsheets lose context fast. Deployed on Render."
    url="/projects/jobtrail"
    target="_self"
    badge="Full-Stack"
  />

  <div class="mt-16 mb-8">
    <div class="text-3xl w-full font-bold mb-2">Client work {"</>"}</div>
    <p class="text-sm opacity-75 mb-5">Shipped for real clients — real requirements, real deadlines, real users.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <ClientCard
        title="J.Kloting"
        desc="Marketing site and quote system for a custom apparel printer in Bulacan. Portfolio filtering, pricing breakdown, AJAX forms with spam protection."
        status="Live"
        stack="Bootstrap 4 · jQuery · Cloudflare Workers"
        url="https://jkloting.store/"
        detailUrl="/projects/jkloting"
      />
      <ClientCard
        title="8Con Academy"
        desc="Official site for a forex derivatives trading school in Bulacan — program overview, 3-level curriculum, and enrollment inquiry form with Express email backend."
        status="Live"
        stack="React 19 · Vite 6 · Express · Nodemailer"
        url="https://www.8conacademy.com/"
        detailUrl="/projects/8conacademy"
      />
      <ClientCard
        title="PCCI Membership Platform"
        desc="Membership management system for a Philippine chamber of commerce — role-based dues tracking, multi-channel payments, automated notifications."
        status="Building"
        stack="Laravel 12 · PostgreSQL · Sanctum · Tailwind"
        stagingUrl="https://pcci-frontend-staging.onrender.com"
      />
    </div>
  </div>


</BaseLayout>
