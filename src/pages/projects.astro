---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-2">Projects</div>
    <div class="mb-5 text-base">
      Three end-to-end projects spanning full-stack web, data engineering, and applied ML.
      Each is shipped, deployed, and runnable today — links below.
    </div>
  </div>

  <div>
    <div class="text-2xl w-full font-bold mb-2 mt-6">Software Engineering</div>
  </div>

  <HorizontalCard
    title="JobTrail — Job Application Tracker"
    img="/projects/jobtrail.gif"
    desc="Full-stack FastAPI + PostgreSQL (Supabase) + HTMX + Tailwind. Magic-link auth, inline create/edit/delete, status filters, weekly applications dashboard. CI green via GitHub Actions, deployed on Render."
    url="/projects/jobtrail"
    target="_self"
    badge="FastAPI · Postgres · HTMX"
  />
  <div class="text-sm mt-1 mb-2">
    <a href="https://github.com/neuralxjam/jobtrail" target="_blank" class="link link-hover">View source →</a>
  </div>
  <div class="divider my-0"></div>

  <div>
    <div class="text-2xl w-full font-bold mb-2 mt-6">Data Engineering</div>
  </div>

  <HorizontalCard
    title="CryptoPulse — Crypto Market ETL & Dashboard"
    img="/projects/cryptopulse.png"
    desc="Daily ETL pipeline pulling top-100 crypto prices from CoinGecko: Python ingest → DuckDB → dbt models (staging + marts) → Streamlit dashboard. Runs every 6h via GitHub Actions. dbt docs site published on GitHub Pages."
    url="/projects/cryptopulse"
    target="_self"
    badge="dbt · DuckDB · Streamlit"
  />
  <div class="text-sm mt-1 mb-2">
    <a href="https://github.com/neuralxjam/cryptopulse" target="_blank" class="link link-hover">View source →</a>
    <span class="mx-2">·</span>
    <a href="https://neuralxjam.github.io/cryptopulse/" target="_blank" class="link link-hover">dbt docs →</a>
  </div>
  <div class="divider my-0"></div>

  <div>
    <div class="text-2xl w-full font-bold mb-2 mt-6">Machine Learning</div>
  </div>

  <HorizontalCard
    title="StaySure — Hotel Booking Cancellation Predictor"
    img="/projects/staysure.png"
    desc="Random Forest classifier reaches F1=0.85 and AUC=0.958 on 119,390 real hotel bookings. Full lifecycle: EDA, feature engineering, sklearn pipelines, model comparison (LR / RF / XGBoost), SHAP explainability, Gradio demo on Hugging Face Spaces."
    url="/projects/staysure"
    target="_self"
    badge="scikit-learn · SHAP · Gradio"
  />
  <div class="text-sm mt-1 mb-2">
    <a href="https://github.com/neuralxjam/staysure" target="_blank" class="link link-hover">View source →</a>
  </div>
</BaseLayout>
