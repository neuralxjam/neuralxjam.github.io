---

<BaseLayout title="MiniLink" sideBarActiveItemID="projects">
  <BackToProjects />
  <div class="mb-6">
    <div class="text-sm uppercase tracking-wide opacity-60">DevOps Â· Software Engineering</div>
    <div class="text-4xl font-bold mt-1">MiniLink</div>
    <div class="text-xl mt-2 opacity-80">Containerized URL Shortener + Analytics</div>
  </div>

  <div class="flex flex-wrap gap-3 mb-8">
    <a href="https://minilink-production.up.railway.app" target="_blank" class="btn btn-primary">Live demo â†’</a>
