---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="J.Kloting" sideBarActiveItemID="projects">
  <div class="mb-6">
    <div class="text-sm uppercase tracking-wide opacity-60">Client Work · Frontend</div>
    <div class="text-4xl font-bold mt-1">J.Kloting</div>
    <div class="text-xl mt-2 opacity-80">Client Landing Page</div>
  </div>

  <div class="flex flex-wrap gap-3 mb-8">
    <a href="https://jkloting.store/" target="_blank" class="btn btn-primary">Live site →</a>
    <a href="https://github.com/neuralxjam/jkloting_website" target="_blank" class="btn btn-outline">View source →</a>
  </div>

  <div class="text-2xl font-bold mb-3">About</div>
  <div class="mb-8 text-base text-justify">
    A marketing landing page built for J.Kloting as a client engagement. The site presents the client's
    offering and contact information at a custom domain
    (<a href="https://jkloting.store/" target="_blank" class="link">jkloting.store</a>).
  </div>

  <div class="text-2xl font-bold mb-3">Scope</div>
  <ul class="list-disc mx-6 mb-8 grid gap-2 text-base">
    <li>Static frontend, deployed at a custom domain</li>
    <li>Custom design — not a template</li>
    <li>Production site for a real client (not a demo or tutorial project)</li>
  </ul>

  <div class="text-2xl font-bold mb-3">Tech</div>
  <div class="overflow-x-auto mb-10">
    <table class="table table-zebra">
      <tbody>
        <tr><td><b>Languages</b></td><td>HTML · CSS · JavaScript</td></tr>
        <tr><td><b>Hosting</b></td><td>Custom domain — <code>jkloting.store</code></td></tr>
        <tr><td><b>Engagement type</b></td><td>Client work</td></tr>
      </tbody>
    </table>
  </div>
</BaseLayout>
