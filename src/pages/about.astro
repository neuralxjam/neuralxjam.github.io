---
import BaseLayout from "../layouts/BaseLayout.astro";

const skills = [
  {
    category: "Languages",
    items: [
      { icon: "python",     label: "Python" },
      { icon: "javascript", label: "JavaScript" },
      { abbr: "SQL",        label: "SQL" },
    ],
  },
  {
    category: "Backend",
    items: [
      { icon: "fastapi",   label: "FastAPI" },
      { icon: "nodedotjs", label: "Node.js" },
      { icon: "express",   label: "Express" },
      { icon: "strapi",    label: "Strapi" },
    ],
  },
  {
    category: "Frontend",
    items: [
      { icon: "react",       label: "React" },
      { icon: "htmx",        label: "HTMX" },
      { icon: "tailwindcss", label: "Tailwind" },
    ],
  },
  {
    category: "Databases",
    items: [
      { icon: "postgresql", label: "PostgreSQL" },
      { icon: "mysql",      label: "MySQL" },
      { icon: "duckdb",     label: "DuckDB" },
      { icon: "redis",      label: "Redis" },
      { icon: "supabase",   label: "Supabase" },
    ],
  },
  {
    category: "Data & ML",
    items: [
      { icon: "pandas",      label: "pandas" },
      { icon: "dbt",         label: "dbt" },
      { icon: "scikitlearn", label: "scikit-learn" },
      { icon: "streamlit",   label: "Streamlit" },
      { abbr: "XGB",         label: "XGBoost" },
      { abbr: "SHAP",        label: "SHAP" },
    ],
  },
  {
    category: "DevOps & Infra",
    items: [
      { icon: "docker",        label: "Docker" },
      { icon: "githubactions", label: "GH Actions" },
      { icon: "nginx",         label: "Nginx" },
      { icon: "git",           label: "Git" },
    ],
  },
  {
    category: "Platforms & Tools",
    items: [
      { icon: "render",           label: "Render" },
      { icon: "railway",          label: "Railway" },
      { icon: "huggingface",      label: "Hugging Face" },
      { icon: "visualstudiocode", label: "VS Code" },
      { icon: "jupyter",          label: "Jupyter" },
    ],
  },
];
---

<BaseLayout title="About" sideBarActiveItemID="about">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">About</div>
  </div>

  <div class="mb-10 text-justify text-base">
    I'm <b>Jhames Andrew Macabata</b>, a Computer Science graduate from 8Con Academy in the Philippines.
    I'm building toward a career at the intersection of software engineering, data, and AI —
    domains I find genuinely exciting because they produce things that work in the real world.
    My background started on the frontend (HTML, JavaScript, web apps), and I'm now deliberately
    expanding into backend development, data engineering, and machine learning through hands-on project work.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">What I'm building toward</div>
  </div>

  <div class="mb-10 text-base">
    I'm targeting entry-level roles in:
    <ul class="list-disc mx-6 mt-3 grid gap-2">
      <li><b>Software Engineering</b> — full-stack web applications with real backends, auth, databases, and deployment.</li>
      <li><b>Data Engineering</b> — automated pipelines, transformations, and dashboards that turn raw data into usable insights.</li>
      <li><b>AI / Machine Learning</b> — end-to-end ML projects: clean data, train models, explain predictions, deploy demos.</li>
    </ul>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Technical skills</div>
  </div>

  <div class="mb-10 space-y-6">
    {skills.map(({ category, items }) => (
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest opacity-50 mb-3">{category}</p>
        <div class="flex flex-wrap gap-4">
          {items.map((item) => (
            <div class="flex flex-col items-center gap-1.5 w-14">
              <div class="bg-base-200 rounded-xl w-11 h-11 flex items-center justify-center">
                {'icon' in item ? (
                  <img
                    src={`https://cdn.simpleicons.org/${item.icon}`}
                    alt={item.label}
                    class="w-6 h-6"
                    loading="lazy"
                  />
                ) : (
                  <span class="text-[10px] font-bold">{item.abbr}</span>
                )}
              </div>
              <span class="text-[10px] text-center leading-tight">{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">How I work</div>
  </div>

  <div class="mb-10 text-justify text-base">
    I learn best by building real things with a clear purpose. Each project in this portfolio solves an actual problem,
    ships to a live URL, and reflects what I'd bring to a real team — not just "I followed a tutorial." I'm comfortable
    asking for help when stuck, breaking problems into small steps, and iterating toward something that actually works.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Goals</div>
  </div>

  <div class="mb-10 text-base">
    <p class="mb-3"><b>Short-term:</b> Land an entry-level role where I can contribute quickly and grow fast.</p>
    <p><b>Long-term:</b> Become a well-rounded engineer who can move fluidly between software, data, and ML layers — the kind of person who can understand a business problem end-to-end and build a solution for it.</p>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="mb-10 text-base">
    <b>Bachelor of Science in Computer Science</b><br>
    8Con Academy
  </div>

</BaseLayout>
