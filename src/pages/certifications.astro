---
import BaseLayout from "../layouts/BaseLayout.astro";

const certs = [
  // Data & Python
  { group: "Data & Python", title: "Data Manipulation with pandas",    slug: "data-manipulation-with-pandas", date: "Dec 2024" },
  { group: "Data & Python", title: "Intermediate Python",              slug: "intermediate-python", date: "Dec 2024" },
  { group: "Data & Python", title: "Introduction to Python",           slug: "intro-python", date: "Nov 2024" },
  { group: "Data & Python", title: "Intermediate SQL",                 slug: "intermediate-sql", date: "Nov 2025" },
  { group: "Data & Python", title: "Introduction to SQL",              slug: "intro-sql", date: "Nov 2025" },
  { group: "Data & Python", title: "Understanding Machine Learning",   slug: "understanding-ml", date: "Feb 2026" },
  // DevOps & Tools
  { group: "DevOps & Tools", title: "Intermediate Git",                slug: "intermediate-git", date: "Mar 2026" },
  { group: "DevOps & Tools", title: "Introduction to Git",             slug: "introduction-to-git", date: "Feb 2026" },
  { group: "DevOps & Tools", title: "Intermediate GitHub Concepts",    slug: "intermediate-github-concepts", date: "Mar 2026" },
  { group: "DevOps & Tools", title: "Introduction to GitHub Concepts", slug: "introduction-to-github-concepts", date: "Mar 2026" },
  // AI & GenAI
  { group: "AI & GenAI", title: "Generative AI Concepts",             slug: "generative-ai-concepts", date: "Feb 2026" },
  { group: "AI & GenAI", title: "Large Language Models (LLMs) Concepts", slug: "llm-concepts", date: "Feb 2026" },
  { group: "AI & GenAI", title: "Introduction to AI Agents",          slug: "introduction-to-ai-agents", date: "Feb 2026" },
  { group: "AI & GenAI", title: "Introduction to AI for Work",        slug: "introduction-to-ai-for-work", date: "Feb 2026" },
  { group: "AI & GenAI", title: "AI Ethics",                          slug: "ai-ethics", date: "Feb 2026" },
  { group: "AI & GenAI", title: "Understanding ChatGPT",              slug: "understanding-chatgpt", date: "Feb 2026" },
];

const groups = ["Data & Python", "DevOps & Tools", "AI & GenAI"];
---

<BaseLayout title="Certifications" sideBarActiveItemID="certifications">

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Certifications</div>
  </div>
  <p class="text-sm opacity-60 mb-8">All issued by <span class="font-semibold dc-text">DataCamp</span>.</p>

  {groups.map((group) => (
    <div class="mb-10">
      <div class="text-xs font-bold uppercase tracking-widest opacity-40 mb-4">{group}</div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {certs.filter(c => c.group === group).map((cert) => (
          <div
            class="cert-card card bg-base-200 border border-base-300 cursor-pointer hover:shadow-md transition-shadow overflow-hidden"
            data-pdf={`/certifications/${cert.slug}.pdf`}
            data-title={cert.title}
          >
            <!-- Thumbnail -->
            <figure class="relative overflow-hidden" style="aspect-ratio: 16/9;">
              <img
                src={`/certifications/thumbs/${cert.slug}.jpg`}
                alt={cert.title}
                class="w-full h-full object-cover object-top"
              />
            </figure>
            <!-- Card body -->
            <div class="card-body p-3">
              <div class="flex items-start justify-between gap-2">
                <div class="font-semibold text-sm leading-snug">{cert.title}</div>
                <div class="badge badge-secondary shrink-0 text-[10px]">DataCamp</div>
              </div>
              <div class="text-xs opacity-50 mt-1">Completed {cert.date}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}

  <!-- Modal -->
  <dialog id="cert-modal" class="modal">
    <div class="modal-box w-11/12 max-w-4xl p-0 overflow-hidden">
      <div class="flex items-center justify-between px-4 py-3 border-b border-base-300">
        <h3 id="modal-title" class="font-bold text-base"></h3>
        <form method="dialog">
          <button class="btn btn-sm btn-circle btn-ghost">✕</button>
        </form>
      </div>
      <iframe id="modal-iframe" src="" class="w-full border-0" style="height: 75vh;"></iframe>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>

</BaseLayout>

<script>
  function init() {
    const modal = document.getElementById("cert-modal") as HTMLDialogElement;
    const iframe = document.getElementById("modal-iframe") as HTMLIFrameElement;
    const modalTitle = document.getElementById("modal-title") as HTMLElement;

    document.querySelectorAll(".cert-card").forEach((card) => {
      card.addEventListener("click", () => {
        const pdf = card.getAttribute("data-pdf") ?? "";
        const title = card.getAttribute("data-title") ?? "";
        modalTitle.textContent = title;
        iframe.src = pdf;
        modal.showModal();
      });
    });

    modal.addEventListener("close", () => {
      iframe.src = "";
    });
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>

<style>
  [data-theme="lofi"] .badge-secondary {
    background-color: #d1fae5;
    color: #065f46;
    border-color: #a7f3d0;
  }
  [data-theme="dim"] .badge-secondary.dc-badge {
    background-color: rgba(3, 239, 98, 0.15);
    color: #03EF62;
    border-color: transparent;
  }
  [data-theme="lofi"] .dc-text { color: #065f46; }
  [data-theme="dim"]  .dc-text { color: #03EF62; }
</style>
