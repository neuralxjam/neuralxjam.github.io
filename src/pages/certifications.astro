---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Certifications" sideBarActiveItemID="certifications">

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Certifications</div>
  </div>
  <p class="text-sm opacity-60 mb-8">All issued by <a href="https://www.datacamp.com" target="_blank" class="link link-hover font-semibold dc-link">DataCamp</a>.</p>

  <!-- Group 1: Data & Python -->
  <div class="mb-8">
    <div class="text-xs font-bold uppercase tracking-widest opacity-40 mb-4">Data & Python</div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">

      {[
        "Data Manipulation with pandas",
        "Intermediate Python",
        "Introduction to Python",
        "Intermediate SQL",
        "Introduction to SQL",
        "Understanding Machine Learning",
      ].map((title) => (
        <div class="card bg-base-200 border border-base-300">
          <div class="card-body p-4">
            <div class="flex items-start justify-between gap-2 mb-1">
              <div class="font-semibold text-sm leading-snug">{title}</div>
              <span class="shrink-0 text-[10px] font-bold px-1.5 py-0.5 rounded dc-badge">DataCamp</span>
            </div>
            <div class="text-xs opacity-50">Issued by DataCamp</div>
          </div>
        </div>
      ))}

    </div>
  </div>

  <!-- Group 2: DevOps & Tools -->
  <div class="mb-8">
    <div class="text-xs font-bold uppercase tracking-widest opacity-40 mb-4">DevOps & Tools</div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">

      {[
        "Intermediate Git",
        "Introduction to Git",
        "Intermediate GitHub Concepts",
        "Introduction to GitHub Concepts",
      ].map((title) => (
        <div class="card bg-base-200 border border-base-300">
          <div class="card-body p-4">
            <div class="flex items-start justify-between gap-2 mb-1">
              <div class="font-semibold text-sm leading-snug">{title}</div>
              <span class="shrink-0 text-[10px] font-bold px-1.5 py-0.5 rounded dc-badge">DataCamp</span>
            </div>
            <div class="text-xs opacity-50">Issued by DataCamp</div>
          </div>
        </div>
      ))}

    </div>
  </div>

  <!-- Group 3: AI & GenAI -->
  <div class="mb-10">
    <div class="text-xs font-bold uppercase tracking-widest opacity-40 mb-4">AI & GenAI</div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">

      {[
        "Generative AI Concepts",
        "Large Language Models (LLMs) Concepts",
        "Introduction to AI Agents",
        "Introduction to AI for Work",
        "AI Ethics",
        "Understanding ChatGPT",
      ].map((title) => (
        <div class="card bg-base-200 border border-base-300">
          <div class="card-body p-4">
            <div class="flex items-start justify-between gap-2 mb-1">
              <div class="font-semibold text-sm leading-snug">{title}</div>
              <span class="shrink-0 text-[10px] font-bold px-1.5 py-0.5 rounded dc-badge">DataCamp</span>
            </div>
            <div class="text-xs opacity-50">Issued by DataCamp</div>
          </div>
        </div>
      ))}

    </div>
  </div>

</BaseLayout>

<style>
  /* Light mode: muted green — readable without eye-searing contrast */
  [data-theme="lofi"] .dc-badge {
    background-color: #d1fae5;
    color: #065f46;
  }
  [data-theme="lofi"] .dc-link {
    color: #065f46;
  }

  /* Dark mode: DataCamp brand green works fine on dark backgrounds */
  [data-theme="dim"] .dc-badge {
    background-color: rgba(3, 239, 98, 0.15);
    color: #03EF62;
  }
  [data-theme="dim"] .dc-link {
    color: #03EF62;
  }
</style>
